# Django 基础环境变量示例
DJANGO_SECRET_KEY=please-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL 数据库连接配置
MYSQL_DATABASE=safe_travel_system
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# AI 推荐说明配置：local 使用本地模板；deepseek/openai 调云端 API；
# ollama 调本地 Ollama 原生接口；openai_compatible 调本地 OpenAI 兼容接口。
AI_RECOMMENDATION_PROVIDER=local
AI_RECOMMENDATION_TIMEOUT=12

# DeepSeek 云端 API
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI 云端 API
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# 本地模型。Ollama 原生接口示例：LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
# OpenAI 兼容接口示例：LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=not-needed
